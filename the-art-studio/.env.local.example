# The Art Studio — local environment.
#
# Copy this file to ".env.local" and fill in the values.
#
# Leave VITE_USE_SUPABASE=false (or unset) to run against the in-memory
# mock/localStorage backend — the Supabase values are then optional.
#
# Set VITE_USE_SUPABASE=true to use Supabase; the URL and anon key are then
# required (found in your Supabase project: Settings → API).

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_USE_SUPABASE=false
